---
import { Caption, CardTitle, Eyebrow } from "../typography";

interface Detail {
  label: string;
  value: string;
  note?: string;
}

interface Props {
  title: string;
  href: string;
  image: string;
  featured?: boolean;
  details: Detail[];
}

const { title, href, image, featured = false, details } = Astro.props;
---

<a
  class:list={["case-card", featured && "case-card--featured"]}
  href={href}
  style={`--case-image: url("${image}")`}
>
  <div class="case-card__content">
    <CardTitle as="h3" tone="inverse" class="case-card__title">{title}</CardTitle>
    <dl class="case-card__details">
      {
        details.map((detail) => (
          <div class="case-card__detail">
            <dt><Eyebrow as="span" tone="inverse">{detail.label}</Eyebrow></dt>
            <dd>
              <Caption as="span" tone="inverse" class="case-card__value">{detail.value}</Caption>
              {detail.note && (
                <Caption as="span" tone="inverse" class="case-card__note">{detail.note}</Caption>
              )}
            </dd>
          </div>
        ))
      }
    </dl>
  </div>
</a>

<style>
  .case-card {
    --type-size-card-title: clamp(1.75rem, 3vw, 2.35rem);
    position: relative;
    display: flex;
    min-height: 420px;
    overflow: hidden;
    align-items: center;
    border-radius: 16px;
    background-image: linear-gradient(90deg, rgb(0 0 0 / 78%), rgb(0 0 0 / 24%)),
      var(--case-image);
    background-position: center;
    background-size: cover;
    color: #fff;
    text-decoration: none;
    isolation: isolate;
  }

  .case-card::after {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: rgb(0 0 0 / 18%);
    content: "";
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .case-card:hover::after,
  .case-card:focus-visible::after {
    opacity: 1;
  }

  .case-card:focus-visible {
    outline: 4px solid #59a7fd;
    outline-offset: 4px;
  }

  .case-card__content {
    display: grid;
    gap: 28px;
    width: min(100%, 760px);
    padding: clamp(28px, 5vw, 48px);
  }

  :global(.case-card__title) {
    max-width: 15ch;
  }

  .case-card__details {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    margin: 0;
  }

  .case-card__detail {
    display: grid;
    gap: 6px;
    min-width: 0;
  }

  .case-card__detail dd {
    display: grid;
    gap: 2px;
    margin: 0;
  }

  :global(.case-card__value) {
    font-weight: 600;
  }

  :global(.case-card__note) {
    opacity: 0.82;
  }

  @media (max-width: 760px) {
    .case-card {
      min-height: 360px;
      background-image: linear-gradient(180deg, rgb(0 0 0 / 78%), rgb(0 0 0 / 36%)),
        var(--case-image);
    }

    .case-card__details {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
</style>
