---
import { CardTitle } from "../typography";

interface Props {
  title: string;
  href: string;
  image: string;
  featured?: boolean;
  titleMaxWidth?: string;
}

const { title, href, image, featured = false, titleMaxWidth = "28ch" } = Astro.props;
---

<a
  class:list={["case-card", featured && "case-card--featured"]}
  href={href}
  style={`--case-image: url("${image}"); --case-title-max-width: ${titleMaxWidth}`}
>
  <div class="case-card__content">
    <CardTitle as="h3" tone="inverse" class="case-card__title">{title}</CardTitle>
  </div>
</a>

<style>
  .case-card {
    --type-size-card-title: clamp(1.75rem, 3vw, 2.35rem);
    position: relative;
    display: grid;
    min-height: 420px;
    overflow: hidden;
    align-items: end;
    border-radius: 16px;
    background-image: var(--case-image);
    background-position: center;
    background-size: cover;
    color: #fff;
    text-decoration: none;
  }

  .case-card:focus-visible {
    outline: 4px solid #59a7fd;
    outline-offset: 4px;
  }

  .case-card__content {
    box-sizing: border-box;
    display: grid;
    width: 100%;
    padding: clamp(72px, 10vw, 120px) clamp(28px, 5vw, 48px) clamp(28px, 5vw, 48px);
    background: linear-gradient(
      180deg,
      rgb(0 0 0 / 0%) 0%,
      rgb(0 0 0 / 0%) 18%,
      rgb(0 0 0 / 62%) 58%,
      rgb(0 0 0 / 88%) 100%
    );
    text-shadow: 0 1px 16px rgb(0 0 0 / 45%);
  }

  .case-card :global(.case-card__title) {
    max-width: var(--case-title-max-width);
    font-weight: 400;
    line-height: 1.02;
    text-wrap: wrap;
  }

  @media (max-width: 760px) {
    .case-card {
      min-height: 360px;
    }

  }
</style>
