---
import { Body, CardTitle } from "../typography";

interface Props {
  title: string;
  paragraphs: string[];
  image?: {
    src: string;
    alt: string;
  };
}

const { title, paragraphs, image } = Astro.props;
---

<article class:list={["reflection", image && "reflection--with-image"]}>
  <div class="reflection__copy">
    <CardTitle as="h3" class="reflection__title">{title}</CardTitle>
    {paragraphs.map((paragraph) => <Body>{paragraph}</Body>)}
  </div>
  {image && <img class="reflection__image" src={image.src} alt={image.alt} loading="lazy" />}
</article>

<style>
  .reflection {
    display: grid;
    gap: 28px;
    align-items: center;
    padding: clamp(28px, 5vw, 44px);
    border-radius: 8px;
  }

  .reflection--with-image {
    grid-template-columns: minmax(0, 1.1fr) minmax(220px, 0.9fr);
  }

  .reflection__copy {
    display: grid;
    gap: 14px;
  }

  :global(.reflection__title) {
    --type-size-card-title: clamp(1.65rem, 3vw, 2.25rem);
    max-width: none;
    margin-bottom: 4px;
  }

  .reflection__image {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  @media (max-width: 760px) {
    .reflection--with-image {
      grid-template-columns: 1fr;
    }
  }
</style>
