---
interface Props {
  as?: "p" | "div" | "span" | "figcaption";
  class?: string;
  tone?: "default" | "muted" | "subtle" | "inverse";
  [key: string]: unknown;
}

const { as = "p", class: className, tone = "default", ...attrs } = Astro.props;
const Tag = as;
---

<Tag class:list={["type-caption", className]} data-tone={tone === "default" ? undefined : tone} {...attrs}>
  <slot />
</Tag>
