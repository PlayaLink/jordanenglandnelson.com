---
interface Props {
  as?: "h1" | "h2" | "h3" | "div" | "p";
  class?: string;
  tone?: "default" | "muted" | "subtle" | "inverse";
  [key: string]: unknown;
}

const { as = "h2", class: className, tone = "default", ...attrs } = Astro.props;
const Tag = as;
---

<Tag
  class:list={["type-section-heading", className]}
  data-tone={tone === "default" ? undefined : tone}
  {...attrs}
>
  <slot />
</Tag>
