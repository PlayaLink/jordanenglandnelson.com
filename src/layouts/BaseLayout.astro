---
import "../styles/typography.css";

interface Props {
  title?: string;
  description?: string;
  mainClass?: string;
  constrain?: boolean;
  showBackLink?: boolean;
}

const {
  title = "Portfolio",
  description,
  mainClass,
  constrain = true,
  showBackLink = true,
} = Astro.props;
const homeHref = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link href={`${homeHref}images/favicon.png`} rel="shortcut icon" type="image/x-icon" />
    <link href={`${homeHref}images/webclip.png`} rel="apple-touch-icon" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color: #161616;
        background: #f7f2ea;
        font-family: var(--type-font-body);
      }

      body {
        min-height: 100vh;
        margin: 0;
      }

      .site-main {
        min-height: 100vh;
      }

      .site-main--constrained {
        width: min(720px, calc(100% - 40px));
        margin: 0 auto;
        padding: 72px 0;
      }

      a {
        color: inherit;
        text-underline-offset: 0.18em;
      }

      :global(.stack) {
        display: grid;
        gap: 20px;
      }
    </style>
  </head>
  <body>
    <main class:list={["site-main", constrain && "site-main--constrained", mainClass]}>
      <slot />
      {showBackLink && <p><a href={homeHref}>Back to portfolio</a></p>}
    </main>
  </body>
</html>
